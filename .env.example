# Cricket Predictor — environment variable reference
# Copy to .env and adjust values as needed.
# All variables are prefixed with CRICKET_PREDICTOR_

# ── Core paths ────────────────────────────────────────────────────────────────
CRICKET_PREDICTOR_MODEL_ARTIFACT_DIR=artifacts/models
CRICKET_PREDICTOR_SYNTHETIC_DATA_DIR=data/synthetic

# ── ESPN Cricinfo standings (points table) ───────────────────────────────────
# Set to false to disable auto-fetch (predictions will use fallback values).
CRICKET_PREDICTOR_ENABLE_STANDINGS_REFRESH=true

# ESPN Cricinfo series URL for the IPL points table.
# Source page that embeds live Cricbuzz standings JSON (change if URL moves).
# CRICKET_PREDICTOR_CRICINFO_STANDINGS_URL=https://www.delhicapitals.in/points-table

# How often the standings are refreshed in the background (minutes).
CRICKET_PREDICTOR_STANDINGS_REFRESH_MINUTES=30

# ── Cricsheet automatic data refresh ─────────────────────────────────────────
# Set to true to enable daily size-check → download → retrain on startup.
CRICKET_PREDICTOR_ENABLE_CRICSHEET_UPDATES=false

# Directory where ZIP archives are extracted.
CRICKET_PREDICTOR_CRICSHEET_DATA_DIR=data/cricsheet

# Cricsheet archive URLs (change only if the upstream paths move).
CRICKET_PREDICTOR_CRICSHEET_IPL_URL=https://cricsheet.org/downloads/ipl_male_json.zip
CRICKET_PREDICTOR_CRICSHEET_T20_URL=https://cricsheet.org/downloads/t20s_male_json.zip
CRICKET_PREDICTOR_CRICSHEET_RECENT_URL=https://cricsheet.org/downloads/recently_played_30_male_json.zip

# How often the background loop re-checks for updates (hours).
CRICKET_PREDICTOR_CRICSHEET_CHECK_INTERVAL_HOURS=24

# ── In-process live predictions ───────────────────────────────────────────────
# Set to true to start the live-prediction refresh loop.
CRICKET_PREDICTOR_ENABLE_LIVE_UPDATES=false

# Seconds between live-prediction refresh cycles.
CRICKET_PREDICTOR_LIVE_REFRESH_SECONDS=60

# Provider: "mock" (default) or "http" (requires base URL below).
CRICKET_PREDICTOR_LIVE_PROVIDER=mock

# Base URL for the HttpLiveDataProvider (only used when provider = "http").
# CRICKET_PREDICTOR_LIVE_PROVIDER_BASE_URL=https://your-normalised-live-feed
